build/
build2/
build_old2/
out/
out2/
out_test/
out_probe/
out_old*/

# Sidecar build artifacts (post-migration 2026-04-15). Sources are tracked
# under native_sidecar/; the build tree produced by build.ps1 is not.
native_sidecar/build/
resources/ffmpeg_sidecar/
.vs/
.vscode/
*.user
CMakeSettings.json
CMakeUserPresets.json

# Large vendored assets — fetched/staged locally, not tracked
third_party/
models/

# Agent scratch: build scripts, logs, debug dumps — convention is underscore prefix
_*.bat
_*.txt
_*.log
_*.csv
_*/
*.log

# One-off diagnostic dumps agents generate at repo root (raw chat diffs, etc.)
chat_diff*.txt
*_raw.txt

# Exception: audit supersession directory is intentionally tracked (historical reference)
!agents/audits/_superseded/
!agents/audits/_superseded/**

# Congress-check hook local session markers — regenerated each run, not for git
.claude/.congress-warned-*
